# === Telegram ===
# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Whitelist: ТОЛЬКО эти Telegram user ID могут управлять ботом.
# Несколько ID — через запятую. Свой ID можно узнать у @userinfobot.
# Если пусто — бот никого не пустит (fail-closed).
ALLOWED_USER_IDS=111111111,222222222

# === Claude ===
# Ключ Anthropic API. Если используешь подписку Claude (OAuth), можно не задавать —
# SDK подхватит логин из ~/.claude. Для API-ключа раскомментируй:
# ANTHROPIC_API_KEY=sk-ant-...

# Рабочая директория, в которой Claude Code будет работать (cwd проекта).
# По умолчанию — папка, откуда запущен бот.
WORKING_DIR=/Users/me/projects/my-project

# Модель по умолчанию (опционально): opus | sonnet | haiku | claude-opus-4-8 ...
DEFAULT_MODEL=

# Режим разрешений по умолчанию: default | acceptEdits | plan | bypassPermissions
DEFAULT_PERMISSION_MODE=default
